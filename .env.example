# Google Gemini API key (recomendado — plano gratuito em https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo Gemini para chat e resumos (predefinição: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Modelo Gemini para embeddings RAG (predefinição: gemini-embedding-001)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI opcional (só usado se GEMINI_API_KEY não estiver definida)
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4.1-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OCR local opcional — caminho para o Tesseract no Windows
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
