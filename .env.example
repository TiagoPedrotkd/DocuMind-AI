# Google Gemini API key (recomendado — plano gratuito em https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo Gemini para chat e resumos (predefinição: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Modelo Gemini para embeddings RAG (predefinição: gemini-embedding-001)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI opcional (só usado se GEMINI_API_KEY não estiver definida)
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4.1-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OCR local opcional — caminho para o Tesseract no Windows
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Integrações Enterprise (v5) — opcionais ---
# Jira Cloud
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=PROJ

# Confluence Cloud
# CONFLUENCE_URL=https://your-domain.atlassian.net
# CONFLUENCE_EMAIL=your-email@company.com
# CONFLUENCE_API_TOKEN=your_confluence_api_token
# CONFLUENCE_SPACE_KEY=DOCS

# Azure DevOps
# AZURE_DEVOPS_ORG=your-org
# AZURE_DEVOPS_PROJECT=your-project
# AZURE_DEVOPS_PAT=your_personal_access_token

# --- Enterprise Stack (v6) — opcional, Docker Compose ---
# ORCHESTRATOR_MODE=langgraph
# USE_LANGGRAPH=true
# native | langgraph | crewai | autogen

# FastAPI microservice (opcional)
# DOCUMIND_API_URL=http://localhost:8000

# PostgreSQL
# POSTGRES_URL=postgresql://documind:documind@localhost:5432/documind

# Redis
# REDIS_URL=redis://localhost:6379/0

# Neo4j Knowledge Graph
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=documind123
