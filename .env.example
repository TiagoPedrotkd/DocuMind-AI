# Google Gemini API key (recomendado — plano gratuito em https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo Gemini (predefinição: gemini-3.1-flash-lite — 500 pedidos/dia no plano gratuito)
# GEMINI_MODEL=gemini-3.1-flash-lite

# OCR local opcional — caminho para o Tesseract no Windows (se não estiver no PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OpenAI opcional (só usado se GEMINI_API_KEY não estiver definida)
OPENAI_API_KEY=
